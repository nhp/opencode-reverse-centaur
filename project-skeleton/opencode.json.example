{
  "$schema": "https://opencode.ai/config.json",

  // ── SECURITY: This file is committed to git. ──────────────────────
  // NEVER hardcode credentials, tokens, or secrets here.
  // Always use {file:thoughts/.secrets/<name>} substitution.
  // The /commit pre-flight will reject hardcoded secrets.
  //
  // ── Project-Level MCP Configuration ───────────────────────────────
  // NOTE: Each MCP entry must include the FULL definition (type, command/url)
  // because OpenCode does not deep-merge MCP server configs with the global config.
  //
  // Credentials use {file:...} substitution to read from gitignored files
  // in thoughts/.secrets/.
  //
  // See: https://opencode.ai/docs/config/#per-project
  "mcp": {

    // Enable Jira for this project (uses OAuth, no credentials needed)
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": true,
      "oauth": {}
    },

    // Enable Bitbucket with project-specific credentials
    "bitbucket": {
      "type": "local",
      "command": ["npx", "-y", "@aashari/mcp-server-atlassian-bitbucket"],
      "enabled": true,
      "environment": {
        "ATLASSIAN_USER_EMAIL": "{file:thoughts/.secrets/atlassian-email}",
        "ATLASSIAN_API_TOKEN": "{file:thoughts/.secrets/atlassian-api-token}"
      }
    },

    // Enable Kibana with project-specific credentials
    "kibana": {
      "type": "local",
      "command": ["npx", "-y", "@tocharianou/mcp-server-kibana"],
      "enabled": true,
      "environment": {
        "KIBANA_HOST": "{file:thoughts/.secrets/kibana-url}",
        "KIBANA_API_KEY": "{file:thoughts/.secrets/kibana-api-key}"
      }
    }

    // Magento 2 — uncomment to enable:
    // "magento2": {
    //   "type": "local",
    //   "command": ["npx", "-y", "@elgentos/magento2-dev-mcp"],
    //   "enabled": true
    // }
  },

  // ── Model Routing (optional) ──────────────────────────────────────
  // By default, subagents inherit the primary model. To reduce costs,
  // route them to a cheaper model. Adjust provider/model IDs to match
  // your configured provider.
  //
  // NOTE: Command model overrides (e.g. /research, /commit) must be
  // set in the command's markdown frontmatter, not here. The "command"
  // key in opencode.json requires a "template" field and cannot be
  // used for partial overrides of markdown-based commands.

  // "agent": {
  //   "codebase-locator":        { "model": "anthropic/claude-sonnet-4-20250514" },
  //   "codebase-analyzer":       { "model": "anthropic/claude-sonnet-4-20250514" },
  //   "codebase-pattern-finder": { "model": "anthropic/claude-sonnet-4-20250514" },
  //   "thoughts-locator":        { "model": "anthropic/claude-sonnet-4-20250514" },
  //   "thoughts-analyzer":       { "model": "anthropic/claude-sonnet-4-20250514" },
  //   "web-search-researcher":   { "model": "anthropic/claude-sonnet-4-20250514" },
  //   "code-reviewer":           { "model": "anthropic/claude-sonnet-4-20250514" }
  // }
}
