{
  "$schema": "https://opencode.ai/config.json",

  // ── SECURITY: This is your GLOBAL config at ~/.config/opencode/. ──
  // NEVER hardcode credentials here. Use {env:VAR} or {file:path}.
  // Unlike project configs, this file is NOT committed to git.
  //
  // ── Provider ──────────────────────────────────────────────────────
  // Configure your LLM provider. Remove or replace with your own.
  "provider": {
    "YOUR_PROVIDER": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.YOUR_PROVIDER.example/v1"
      },
      "models": {
        "your-model-id": {}
      }
    }
  },

  // ── MCP Servers ───────────────────────────────────────────────────
  // Define ALL MCP servers here. Servers you use across every project
  // can be enabled globally. Project-specific servers should be
  // disabled here and enabled per project in <project>/opencode.json.
  //
  // Credentials: use {env:VAR} or {file:path} substitution.
  // See: https://opencode.ai/docs/config/#variables
  "mcp": {

    // ── Always-on (global) ──
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },

    // ── Project-specific (disabled by default) ──
    // Enable per project in <project>/opencode.json
    "jira": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "enabled": false,
      "oauth": {}
    },
    "bitbucket": {
      "type": "local",
      "command": ["npx", "-y", "@aashari/mcp-server-atlassian-bitbucket"],
      "enabled": false
    },
    "kibana": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic/mcp-server-kibana"],
      "enabled": false
    },
    "magento2": {
      "type": "local",
      "command": ["npx", "-y", "@anthropic/mcp-server-magento2"],
      "enabled": false
    }
  },

  // ── Plugins ───────────────────────────────────────────────────────
  "plugin": [
    "opencode-anthropic-auth@latest"
  ],

  "autoshare": false,
  "autoupdate": true
}
