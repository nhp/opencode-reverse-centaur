# Project Credentials
#
# Copy this file to thoughts/.credentials and fill in your values.
# This file is gitignored (*.credentials) — NEVER commit actual credentials.
#
# Usage (via Claude Code):
#   Run: ./scripts/credentials.sh <section> <key>
#   Example: ./scripts/credentials.sh basic-auth username
#
# Format: TOML sections with key = "value" pairs.

[basic-auth]
username = "joe"
password = "doe"

[frontend]
username = "jane"
password = "doe"

# Add more sections as needed:
#
# [api]
# token = "your-api-token"
# base_url = "https://api.example.com"
#
# [database]
# host = "localhost"
# port = "3306"
# username = "root"
# password = "secret"
# database = "mydb"
